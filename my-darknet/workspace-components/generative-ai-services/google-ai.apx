genAIService google-ai (
    name: Google_AI
    provider: googleGemini
    endpointUrl {
        url: https://generativelanguage.googleapis.com/v1beta
    }
    authentication {
        credentials: @credentials-for-google-ai
    }
    appBuilder {
        usedByAppBuilder: true
        defaultForNewApps: true
    }
    advanced {
        modelName: gemini-3.5-flash
    }
)

